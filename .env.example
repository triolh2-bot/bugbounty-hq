# Flask Configuration
BUGBOUNTYHQ_ENV=development
SECRET_KEY=dev-secret-key-change-me
PORT=5000
DEBUG=False

# Database
DATABASE_URL=sqlite:///bugbounty.db

# Production note: set BUGBOUNTYHQ_ENV=production and replace SECRET_KEY with
# a random 32+ character value before deploying.

# JWT Settings
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION_HOURS=24
